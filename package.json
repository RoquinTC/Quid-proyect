{
  "name": "quid-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Quid Finance App + Aura IA Agent — Monorepo",
  "scripts": {
    "dev:quid": "npm run dev --prefix Quid-App",
    "dev:aura": "npm run dev --prefix ../Aura-Standalone",
    "build:quid": "npm run build --prefix Quid-App",
    "build:aura": "npm run build --prefix ../Aura-Standalone",
    "test": "npm run test --prefix Quid-App",
    "test:watch": "npm run test:watch --prefix Quid-App",
    "lint": "npm run lint --prefix Quid-App",
    "db:generate": "npm run db:generate --prefix Quid-App",
    "db:push": "npm run db:push --prefix Quid-App",
    "postgres:up": "docker compose up -d postgres",
    "postgres:logs": "docker compose logs -f postgres",
    "postgres:down": "docker compose stop postgres",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build --no-cache",
    "docker:build:quid": "docker compose build --no-cache quid-app",
    "docker:build:aura": "npm run build:aura",
    "docker:logs": "docker compose logs -f"
  }
}
