DATABASE_URL=file:../db/custom.db
NEXTAUTH_SECRET=pon-aqui-tu-clave-secreta-aleatoria
# Para generar una clave aleatoria en tu terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Luego pega el resultado como valor de NEXTAUTH_SECRET

# Push Notifications (VAPID keys)
# Generar claves: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=tu-clave-publica-vapid-aqui
VAPID_PRIVATE_KEY=tu-clave-privada-vapid-aqui
VAPID_SUBJECT=mailto:tu@email.com
