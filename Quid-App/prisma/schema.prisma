// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String
  password            String
  avatar              String?
  currency            String    @default("COP")
  telegramId          String?   @unique
  onboardingCompleted Boolean   @default(false)
  onboardingStep      Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts            Account[]
  budgets             Budget[]
  debts               Debt[]
  abonos              Abono[]
  savingsGoals        SavingsGoal[]
  vehicles            Vehicle[]
  medications         Medication[]
  appointments        MedicalAppointment[]
  pantryItems         PantryItem[]
  shoppingLists       ShoppingList[]
  healthProfiles      HealthProfile[]
  sharedAccounts      SharedAccountUser[]
  transactions        Transaction[]
  recurringPayments   RecurringPayment[]
  cdts                CDT[]
  payrollGroups       PayrollGroup[]
  fuelPrices          FuelPrice[]
  categories          Category[]
  settings            UserSettings?
  sentInvitations     AccountInvitation[]  @relation("SentInvitations")
  receivedInvitations AccountInvitation[]  @relation("ReceivedInvitations")
  notifications       AppNotification[]
  pushSubscriptions   PushSubscription[]
  storedBackups       StoredBackup[]
  authCredentials     AuthCredential[]
}

// ============================================
// FINANCE MODULE - ACCOUNTS
// ============================================

model Account {
  id                    String    @id @default(cuid())
  userId                String
  name                  String
  type                  String    @default("checking") // checking, savings, cash, digital_wallet, other
  color                 String    @default("#10B981")
  icon                  String?
  balance               Decimal   @default(0) // CHANGED: Float -> Decimal (exact money storage)
  isHighYield           Boolean   @default(false)
  yieldPercentage       Decimal?  // CHANGED: Float -> Decimal (financial rate)
  isShared              Boolean   @default(false)
  excludeFromAvailable  Boolean   @default(false)
  order                 Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subAccounts           SubAccount[]
  transactions          Transaction[]
  yieldHistory          YieldRecord[]
  sharedUsers           SharedAccountUser[]
  invitations           AccountInvitation[]
  recurringPayments     RecurringPayment[]
  recurringDestPayments RecurringPayment[] @relation("RecurringDestination")
  cdts                  CDT[]
  savingsGoalLinks      SavingsGoalAccount[]
  goalSources           SavingsGoal[] @relation("GoalSourceAccount")
  goalDestinations      SavingsGoal[] @relation("GoalDestinationAccount")
  payrollGroups         PayrollGroup[]
  // ── Transport relations ──
  fuelLogPayments       FuelLog[]           @relation("FuelLogAccount")
  maintenancePayments   MaintenanceRecord[] @relation("MaintenanceAccount")
  vehicleDocumentPayments VehicleDocument[] @relation("VehicleDocumentAccount")
  paymentDefaultVehicles VehiclePaymentDefault[] @relation("PaymentDefaultAccount")

  @@map("accounts")
}

model SubAccount {
  id                    String    @id @default(cuid())
  accountId             String
  name                  String
  type                  String    @default("pocket") // pocket, piggy_bank, savings_box, other
  balance               Decimal   @default(0) // CHANGED: Float -> Decimal
  isHighYield           Boolean   @default(false)
  yieldPercentage       Decimal?  // CHANGED: Float -> Decimal
  icon                  String?
  color                 String?
  excludeFromAvailable  Boolean   @default(false)
  order                 Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  account               Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  yieldHistory          YieldRecord[]
  savingsGoalLinks      SavingsGoalAccount[]
  recurringPayments     RecurringPayment[]
  payrollGroups         PayrollGroup[]
  // ── Transport relations ──
  fuelLogPayments       FuelLog[]           @relation("FuelLogSubAccount")
  maintenancePayments   MaintenanceRecord[] @relation("MaintenanceSubAccount")
  vehicleDocumentPayments VehicleDocument[] @relation("VehicleDocumentSubAccount")
  paymentDefaultVehicles VehiclePaymentDefault[] @relation("PaymentDefaultSubAccount")

  @@map("sub_accounts")
}

model SharedAccountUser {
  id        String   @id @default(cuid())
  accountId String
  userId    String
  role      String   @default("editor") // viewer, editor
  createdAt DateTime @default(now())

  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountId, userId])
  @@map("shared_account_users")
}

model AccountInvitation {
  id          String    @id @default(cuid())
  accountId   String
  inviterId   String    // Who sent the invitation (admin)
  inviteeId   String    // Who receives the invitation
  inviteeEmail String   // Email at time of invitation (for display)
  role        String    @default("editor") // viewer, editor
  status      String    @default("pending") // pending, accepted, rejected, expired
  message     String?   // Optional message from inviter
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  inviter     User      @relation("SentInvitations", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee     User      @relation("ReceivedInvitations", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@map("account_invitations")
}

model AppNotification {
  id          String    @id @default(cuid())
  userId      String    // Who receives the notification
  type        String    // invitation_sent, invitation_received, invitation_accepted, invitation_rejected, shared_transaction, member_removed, role_changed, recurring_due
  title       String
  message     String
  read        Boolean   @default(false)
  data        String?   // JSON string with extra data (accountId, invitationId, etc.)
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("app_notifications")
}

model YieldRecord {
  id              String    @id @default(cuid())
  accountId       String?
  subAccountId    String?
  month           DateTime  // First day of the month
  projectedYield  Decimal   // CHANGED: Float -> Decimal
  actualYield     Decimal?  // CHANGED: Float -> Decimal
  yieldPercentage Decimal   // CHANGED: Float -> Decimal
  isConfirmed     Boolean   @default(false)
  transactionId   String?   // Links to the income Transaction created when yield is confirmed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  account         Account?    @relation(fields: [accountId], references: [id])
  subAccount      SubAccount? @relation(fields: [subAccountId], references: [id])

  @@map("yield_records")
}

// ============================================
// FINANCE MODULE - TRANSACTIONS
// ============================================

model Transaction {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String?
  subAccountId          String?
  type                  String    // income, expense, transfer
  amount                Decimal   // CHANGED: Float -> Decimal
  description           String
  category              String?
  subCategory           String?
  date                  DateTime
  sourceModule          String?   // finance, transport, pantry, health
  sourceId              String?   // ID of related record in another module
  isRecurring           Boolean   @default(false)
  notes                 String?
  relatedTransactionId  String?   // Links transfer pairs
  excludeFromBudget     Boolean?  @default(false) // If true, does not affect budget spent
  receiptUrl            String?   // URL of attached receipt/photo
  receiptThumbnail      String?   // Thumbnail URL for quick preview
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  account         Account?   @relation(fields: [accountId], references: [id])
  subAccount      SubAccount? @relation(fields: [subAccountId], references: [id])

  @@map("transactions")
}

// ============================================
// FINANCE MODULE - BUDGETS
// ============================================

model Budget {
  id            String    @id @default(cuid())
  userId        String
  type          String    // income, expense
  category      String
  subCategory   String?
  amount        Decimal   // CHANGED: Float -> Decimal (total budget)
  spent         Decimal   @default(0) // CHANGED: Float -> Decimal (amount spent)
  period        String    @default("monthly") // monthly, weekly, yearly
  lastResetDate DateTime? // When was spent last reset to 0
  icon          String?
  color         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("budgets")
}

// ============================================
// FINANCE MODULE - DEBTS
// ============================================

model Debt {
  id              String    @id @default(cuid())
  userId          String
  type            String    // credit_card, loan, other
  name            String
  color           String    @default("#EF4444")
  icon            String?
  bank            String?
  totalAmount     Decimal   // CHANGED: Float -> Decimal
  currentBalance  Decimal   // CHANGED: Float -> Decimal
  interestRate    Decimal?  // CHANGED: Float -> Decimal
  cutoffDate      Int?      // Day of month for cutoff (credit card)
  paymentDate     Int?      // Day of month for payment (credit card)
  monthlyPayment  Decimal?  // CHANGED: Float -> Decimal
  remainingPayments Int?
  startDate       DateTime?
  endDate         DateTime?
  // ── Loan-specific fields ──
  paymentType     String?   // "fixed" or "variable" (for loans)
  otherCharges    Decimal?  // CHANGED: Float -> Decimal
  category        String?   // Budget category (for loan payments)
  subCategory     String?   // Budget sub-category
  accountId       String?   // Default payment account (for loans)
  subAccountId    String?   // Default payment sub-account
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  installments    Installment[]
  abonos          Abono[]
  recurringPayments RecurringPayment[]
  // ── Transport relations ──
  fuelLogPayments       FuelLog[]           @relation("FuelLogDebt")
  maintenancePayments   MaintenanceRecord[] @relation("MaintenanceDebt")
  vehicleDocumentPayments VehicleDocument[] @relation("VehicleDocumentDebt")
  paymentDefaultVehicles VehiclePaymentDefault[] @relation("PaymentDefaultDebt")

  @@map("debts")
}

model Installment {
  id                  String    @id @default(cuid())
  debtId              String
  description         String
  totalAmount         Decimal   // CHANGED: Float -> Decimal
  totalInstallments   Int
  currentInstallment  Int       @default(1)
  installmentAmount   Decimal   // CHANGED: Float -> Decimal
  paidAmount          Decimal   @default(0) // CHANGED: Float -> Decimal
  interestRate        Decimal?  // CHANGED: Float -> Decimal
  interestAmount      Decimal?  // CHANGED: Float -> Decimal
  otherChargesAmount  Decimal?  // CHANGED: Float -> Decimal
  remainingBalance    Decimal?  // CHANGED: Float -> Decimal
  purchaseDate        DateTime
  nextPaymentDate     DateTime
  isPaid              Boolean   @default(false)
  accountId           String?   // Cuenta desde donde se debita el pago
  subAccountId        String?   // Subcuenta especifica (opcional)
  category            String?   // Categoria de presupuesto
  subCategory         String?   // Subcategoria de presupuesto
  recurringPaymentId  String?   // ID del pago recurrente que origino esta compra
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  debt                Debt      @relation(fields: [debtId], references: [id], onDelete: Cascade)
  abonoDetails        AbonoDetail[]

  @@map("installments")
}

model Abono {
  id              String    @id @default(cuid())
  userId          String
  debtId          String
  transactionId   String?   // Links to the expense Transaction (null if transaction was deleted)
  totalAmount     Decimal   // CHANGED: Float -> Decimal
  accountId       String    // Account from which the abono was paid
  subAccountId    String?   // Sub-account (optional)
  date            DateTime  // Date of the abono
  isReversed      Boolean   @default(false) // Whether this abono has been reversed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  debt            Debt      @relation(fields: [debtId], references: [id], onDelete: Cascade)
  details         AbonoDetail[]

  @@map("abonos")
}

model AbonoDetail {
  id              String  @id @default(cuid())
  abonoId         String
  installmentId   String
  amount          Decimal // CHANGED: Float -> Decimal
  previousBalance Decimal // CHANGED: Float -> Decimal
  newBalance      Decimal // CHANGED: Float -> Decimal

  abono           Abono       @relation(fields: [abonoId], references: [id], onDelete: Cascade)
  installment     Installment @relation(fields: [installmentId], references: [id], onDelete: Cascade)

  @@map("abono_details")
}

// ============================================
// FINANCE MODULE - RECURRING PAYMENTS
// ============================================

model RecurringPayment {
  id                      String    @id @default(cuid())
  userId                  String
  description             String
  amount                  Decimal   // CHANGED: Float -> Decimal
  actualAmount            Decimal?  // CHANGED: Float -> Decimal
  type                    String    @default("expense") // expense, transfer
  accountId               String?   // Source account (or account that pays TC bill when debtId is set)
  subAccountId            String?   // Sub-account within the paying account
  debtId                  String?   // Source debt (for credit card payments)
  destinationAccountId    String?   // Destination account (for transfer type)
  destinationSubAccountId String?   // Destination sub-account (for transfer type)
  category                String?
  subCategory             String?
  scheduledDate           DateTime  // When the payment is scheduled
  confirmedDate           DateTime? // When it was actually confirmed
  status                  String    @default("pending") // pending, confirmed, cancelled
  frequency               String    @default("monthly") // monthly, weekly, yearly, one_time
  notes                   String?
  isRecurring             Boolean   @default(true)
  // New fields for savings goal integration
  savingsGoalId           String?   // Meta de ahorro vinculada
  customDays              String?   // JSON array de dias personalizados
  periodAmounts           String?   // JSON array de montos por periodo
  payrollGroupId          String?   // Link to payroll group (for salary-type recurring payments)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  account            Account?   @relation(fields: [accountId], references: [id])
  subAccount         SubAccount? @relation(fields: [subAccountId], references: [id])
  debt               Debt?      @relation(fields: [debtId], references: [id])
  destinationAccount Account?   @relation("RecurringDestination", fields: [destinationAccountId], references: [id])
  savingsGoal        SavingsGoal? @relation(fields: [savingsGoalId], references: [id])
  payrollGroup       PayrollGroup? @relation(fields: [payrollGroupId], references: [id], onDelete: Cascade)

  @@map("recurring_payments")
}

// ============================================
// FINANCE MODULE - PAYROLL ASSISTANT (NÓMINA)
// ============================================

model PayrollGroup {
  id                    String    @id @default(cuid())
  userId                String
  description           String    @default("Sueldo")
  frequency             String    // "monthly", "biweekly", "weekly"
  totalAmount           Decimal   // CHANGED: Float -> Decimal
  accountId             String    // Account where income is received
  subAccountId          String?   // Optional sub-account
  category              String    @default("Sueldo")
  subCategory           String?
  adjustToBusinessDay   Boolean   @default(false) // Adjust date if falls on weekend/holiday
  businessDayDirection  String    @default("before") // "before" or "after"
  schedules             String    // JSON array: [{day: 15, amount: 1500000}, ...] for monthly/biweekly; [{dayOfWeek: 6, amount: 500000}] for weekly
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  account           Account    @relation(fields: [accountId], references: [id])
  subAccount        SubAccount? @relation(fields: [subAccountId], references: [id])
  recurringPayments  RecurringPayment[]

  @@map("payroll_groups")
}

// ============================================
// FINANCE MODULE - SAVINGS & GOALS
// ============================================

model SavingsGoal {
  id              String    @id @default(cuid())
  userId          String
  name            String
  description     String?
  targetAmount    Decimal   // CHANGED: Float -> Decimal
  currentAmount   Decimal   @default(0) // CHANGED: Float -> Decimal
  deadline        DateTime?
  icon            String?
  color           String    @default("#8B5CF6")
  type            String    @default("general") // emergency_fund, education, general, travel, etc
  aiSuggestion    String?
  isActive        Boolean   @default(true)
  // New fields for frequency and scheduling
  frequency       String    @default("mensual") // "mensual", "quincenal", "semanal"
  monthlyDay      Int?      // Dia del mes para frecuencia mensual (1-31)
  biweeklyDays    String?   // JSON array de 2 dias, e.g. "[1,15]"
  weeklyDay       Int?      // Dia de la semana (0=domingo, 1=lunes...6=sabado)
  periodAmounts   String?   // JSON array de montos por periodo
  sourceAccountId       String?   // Cuenta origen de los aportes (de donde sale el dinero)
  destinationAccountId  String?   // Cuenta destino de los aportes (donde se acumula el ahorro)
  status          String    @default("activa") // "activa", "completada", "cancelada"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions   SavingsContribution[]
  cdts            CDT[]
  linkedAccounts  SavingsGoalAccount[]
  sourceAccount       Account?  @relation("GoalSourceAccount", fields: [sourceAccountId], references: [id])
  destinationAccount  Account?  @relation("GoalDestinationAccount", fields: [destinationAccountId], references: [id])
  recurringPayments RecurringPayment[]

  @@map("savings_goals")
}

model SavingsGoalAccount {
  id              String    @id @default(cuid())
  goalId          String
  accountId       String
  subAccountId    String?   // Optional: specific sub-account within the account
  createdAt       DateTime  @default(now())

  goal            SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  account         Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subAccount      SubAccount? @relation(fields: [subAccountId], references: [id], onDelete: Cascade)

  @@unique([goalId, accountId, subAccountId])
  @@map("savings_goal_accounts")
}

model SavingsContribution {
  id            String    @id @default(cuid())
  goalId        String
  amount        Decimal   // CHANGED: Float -> Decimal
  date          DateTime
  description   String?
  transactionId String?   // Links to the expense Transaction created when debiting
  accountId     String?   // Which account was debited
  createdAt     DateTime  @default(now())

  goal          SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@map("savings_contributions")
}

// ============================================
// FINANCE MODULE - CDT (Certificados de Deposito a Termino)
// ============================================

model CDT {
  id              String    @id @default(cuid())
  userId          String
  bank            String    // Banco emisor
  amount          Decimal   // CHANGED: Float -> Decimal
  effectiveRate   Decimal   // CHANGED: Float -> Decimal (%EA)
  startDate       DateTime  // Fecha de apertura
  endDate         DateTime  // Fecha de vencimiento
  termDays        Int       // Plazo en dias (30, 60, 90, 180, 360, etc.)
  interestEarned  Decimal   @default(0) // CHANGED: Float -> Decimal
  status          String    @default("active") // active, matured, withdrawn, renewed
  goalId          String?   // Vinculacion opcional a una meta de ahorro
  accountId       String?   // Cuenta donde se depositan los rendimientos
  withdrawnAmount Decimal?  // CHANGED: Float -> Decimal
  withdrawnDate   DateTime? // Fecha de retiro
  notes           String?
  color           String    @default("#14B8A6")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal            SavingsGoal?  @relation(fields: [goalId], references: [id], onDelete: SetNull)
  account         Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@map("cdts")
}

// ============================================
// TRANSPORT MODULE
// ============================================

model Vehicle {
  id              String    @id @default(cuid())
  userId          String
  name            String
  type            String    @default("motorcycle") // motorcycle, car, truck, other
  brand           String?
  model           String?
  year            Int?
  color           String?
  tankCapacity    Float?    // in gallons (NOT money — stays Float)
  fuelType        String?   // gasoline, diesel, electric
  currentKm       Float     @default(0) // distance (NOT money — stays Float)
  plate           String?
  icon            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fuelLogs        FuelLog[]
  maintenanceRecords MaintenanceRecord[]
  documents       VehicleDocument[]
  paymentDefault  VehiclePaymentDefault?

  @@map("vehicles")
}

model FuelLog {
  id              String    @id @default(cuid())
  vehicleId       String
  date            DateTime
  km              Float     // distance (NOT money — stays Float)
  amount          Decimal   // CHANGED: Float -> Decimal (money paid)
  pricePerGallon  Decimal   // CHANGED: Float -> Decimal (fuel price)
  gallons         Float     // volume (NOT money — stays Float)
  isFullTank      Boolean   @default(true)
  station         String?   // Gas station name
  // ── Finance integration fields ──
  accountId       String?   // Account used for payment (null = no account linked)
  subAccountId    String?   // Sub-account (bolsillo) if applicable
  debtId          String?   // Credit card used for payment (if TC)
  installmentCount Int?     // Number of installments if paid with TC
  notes           String?
  createdAt       DateTime  @default(now())

  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  account         Account?  @relation("FuelLogAccount", fields: [accountId], references: [id])
  subAccount      SubAccount? @relation("FuelLogSubAccount", fields: [subAccountId], references: [id])
  debt            Debt?     @relation("FuelLogDebt", fields: [debtId], references: [id])

  @@map("fuel_logs")
}

model MaintenanceRecord {
  id              String    @id @default(cuid())
  vehicleId       String
  type            String    // oil_change, tire_change, brake_service, general, parts_replacement, alignment, suspension, transmission, electrical, cooling, ac, battery, inspection, wash, aesthetics, other
  description     String
  cost            Decimal   // CHANGED: Float -> Decimal
  km              Float     // distance (NOT money — stays Float)
  date            DateTime
  nextDueKm       Float?    // distance (NOT money — stays Float)
  nextDueDate     DateTime?
  reminderEnabled Boolean   @default(true)
  // ── Finance integration fields ──
  accountId       String?   // Account used for payment
  subAccountId    String?   // Sub-account (bolsillo) if applicable
  debtId          String?   // Credit card used for payment (if TC)
  installmentCount Int?     // Number of installments if paid with TC
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  items           MaintenanceItem[]
  account         Account?  @relation("MaintenanceAccount", fields: [accountId], references: [id])
  subAccount      SubAccount? @relation("MaintenanceSubAccount", fields: [subAccountId], references: [id])
  debt            Debt?     @relation("MaintenanceDebt", fields: [debtId], references: [id])

  @@map("maintenance_records")
}

// ============================================
// TRANSPORT MODULE - EXTENDED MODELS
// ============================================

model VehicleDocument {
  id              String    @id @default(cuid())
  vehicleId       String
  type            String    // soat, tecnomecanica, seguro, impuesto, otro
  documentNumber  String?   // SOAT policy #, Tecnomecánica #, etc.
  issueDate       DateTime  // When it was issued/purchased
  expiryDate      DateTime  // When it expires
  cost            Decimal   // CHANGED: Float -> Decimal (money paid)
  reminderDays    Int       @default(30) // Days before expiry to trigger reminder
  reminderEnabled Boolean   @default(true)
  // ── Finance integration fields ──
  accountId       String?   // Account used for payment
  subAccountId    String?   // Sub-account (bolsillo) if applicable
  debtId          String?   // Credit card used for payment (if TC)
  installmentCount Int?     // Number of installments if paid with TC
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  account         Account?  @relation("VehicleDocumentAccount", fields: [accountId], references: [id])
  subAccount      SubAccount? @relation("VehicleDocumentSubAccount", fields: [subAccountId], references: [id])
  debt            Debt?     @relation("VehicleDocumentDebt", fields: [debtId], references: [id])

  @@map("vehicle_documents")
}

model MaintenanceItem {
  id                  String    @id @default(cuid())
  maintenanceRecordId String
  name                String    // e.g. "Aceite sintético 10W-40", "Filtro de aire"
  quantity            Float     @default(1) // item count (NOT money — stays Float)
  unitPrice           Decimal   // CHANGED: Float -> Decimal (money)
  totalPrice          Decimal   // CHANGED: Float -> Decimal (money) = quantity * unitPrice
  notes               String?
  createdAt           DateTime  @default(now())

  maintenanceRecord   MaintenanceRecord @relation(fields: [maintenanceRecordId], references: [id], onDelete: Cascade)

  @@map("maintenance_items")
}

model VehiclePaymentDefault {
  id              String    @id @default(cuid())
  vehicleId       String    @unique // One default per vehicle
  userId          String
  paymentType     String    @default("account") // "account" or "credit_card"
  accountId       String?   // Default account for payment
  subAccountId    String?   // Default sub-account (bolsillo)
  debtId          String?   // Default credit card (if paymentType = credit_card)
  installmentCount Int?     // Default # of installments for TC
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  account         Account?  @relation("PaymentDefaultAccount", fields: [accountId], references: [id])
  subAccount      SubAccount? @relation("PaymentDefaultSubAccount", fields: [subAccountId], references: [id])
  debt            Debt?     @relation("PaymentDefaultDebt", fields: [debtId], references: [id])

  @@map("vehicle_payment_defaults")
}

// ============================================
// HEALTH MODULE
// ============================================

model Medication {
  id              String    @id @default(cuid())
  userId          String
  name            String
  dosage          String
  frequency       String    @default("daily") // daily, twice_daily, weekly, as_needed, custom
  customSchedule  String?   // JSON for custom schedule
  disease         String?
  howToTake       String?   // with_food, without_food, morning, night
  startDate       DateTime?
  endDate         DateTime?
  isActive        Boolean   @default(true)
  reminderEnabled Boolean   @default(true)
  reminderTimes   String?   // JSON array of times e.g. ["08:00","20:00"]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("medications")
}

model MedicalAppointment {
  id              String    @id @default(cuid())
  userId          String
  doctorName      String?
  specialty       String?
  location        String?
  date            DateTime
  notes           String?
  reminderEnabled Boolean   @default(true)
  status          String    @default("scheduled") // scheduled, completed, cancelled
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("medical_appointments")
}

// ============================================
// PANTRY MODULE
// ============================================

model PantryItem {
  id              String    @id @default(cuid())
  userId          String
  name            String
  category        String?   // dairy, meat, vegetables, fruits, grains, beverages, snacks, condiments, other
  quantity        Float     // item count/volume (NOT money — stays Float)
  unit            String    @default("unit") // unit, lb, kg, g, oz, ml, l, package, bottle, can
  expirationDate  DateTime?
  purchaseDate    DateTime?
  purchasePrice   Decimal?  // CHANGED: Float -> Decimal (money)
  minStock        Float?    // threshold (NOT money — stays Float)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("pantry_items")
}

model ShoppingList {
  id              String    @id @default(cuid())
  userId          String
  name            String    @default("Lista de Mercado")
  status          String    @default("draft") // draft, shopping, verified, completed
  profileId       String?   // Health profile to consider
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           ShoppingListItem[]

  @@map("shopping_lists")
}

model ShoppingListItem {
  id              String    @id @default(cuid())
  shoppingListId  String
  name            String
  quantity        Float     // item count (NOT money — stays Float)
  unit            String    @default("unit")
  estimatedPrice  Decimal?  // CHANGED: Float -> Decimal (money)
  actualPrice     Decimal?  // CHANGED: Float -> Decimal (money)
  isPurchased     Boolean   @default(false)
  checked         Boolean   @default(false)
  pantryItemId    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  shoppingList    ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)

  @@map("shopping_list_items")
}

model HealthProfile {
  id              String    @id @default(cuid())
  userId          String
  name            String
  type            String    @default("owner") // owner, guest
  diseases        String?   // JSON array of diseases
  restrictions    String?   // JSON array of food restrictions
  aiRestrictions  String?   // AI-generated restrictions based on diseases
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("health_profiles")
}

// ============================================
// FUEL PRICE PARAMETER
// ============================================

model FuelPrice {
  id              String    @id @default(cuid())
  userId          String
  fuelType        String    @default("gasoline")
  pricePerGallon  Decimal   // CHANGED: Float -> Decimal (money)
  updatedAt       DateTime  @updatedAt
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("fuel_prices")
}

// ============================================
// CUSTOM CATEGORIES
// ============================================

model Category {
  id          String   @id @default(cuid())
  userId      String
  type        String   // income, expense
  name        String
  icon        String?  // lucide icon name
  color       String?  // hex color
  hidden      Boolean  @default(false) // hide default categories the user removed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, name])
  @@map("custom_categories")
}

// ============================================
// PUSH NOTIFICATIONS
// ============================================

model PushSubscription {
  id          String   @id @default(cuid())
  userId      String
  endpoint    String   @unique
  p256dh      String   // Client public key
  auth        String   // Client auth secret
  userAgent   String?  // Browser/device info
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// ============================================
// USER SETTINGS
// ============================================

model UserSettings {
  id                  String    @id @default(cuid())
  userId              String    @unique
  theme               String    @default("light") // light, dark, system
  budgetCutoffDay     Int       @default(1) // Day of month (1-31) for budget period start
  respectHolidays     Boolean   @default(true) // Consider holidays for business day calculation
  countryCode         String    @default("CO") // For holiday calculations
  lastBudgetReset     DateTime? // When budgets were last reset
  notificationsEnabled Boolean  @default(true) // Global notifications toggle
  pinEnabled          Boolean   @default(false) // PIN lock enabled
  pinHash             String?                    // bcrypt hash of the 4-digit PIN
  biometricEnabled    Boolean   @default(false) // Biometric auth enabled
  lockOnResume        Boolean   @default(true)  // Lock when app comes back to foreground
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ============================================
// STORED BACKUPS (Server-side)
// ============================================

model StoredBackup {
  id          String   @id @default(cuid())
  userId      String
  data        String   // JSON string with the full backup data
  version     Int      // Backup schema version
  recordCount Int      // Total number of records in the backup
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("stored_backups")
}

// ============================================
// WEBAUTHN CREDENTIALS
// ============================================

model AuthCredential {
  id              String   @id @default(cuid())
  userId          String
  credentialId    String   @unique   // Base64url-encoded credential ID
  publicKey       String             // Base64url-encoded public key
  counter         Int      @default(0)
  deviceType      String?            // "platform" (fingerprint/face) or "cross-platform" (security key)
  backedUp        Boolean  @default(false)
  transports      String?            // JSON array of transports
  name            String?            // User-given name like "Dedo índice"
  createdAt       DateTime @default(now())
  lastUsedAt      DateTime?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_credentials")
}
