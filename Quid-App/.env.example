DATABASE_URL=postgresql://quid:quid-local-dev@localhost:5432/quid?schema=public
POSTGRES_DATABASE_URL=postgresql://quid:quid-local-dev@localhost:5432/quid?schema=public
SQLITE_DATABASE_URL=file:./db/custom.db
NEXTAUTH_SECRET=pon-aqui-tu-clave-secreta-aleatoria
# En producción HTTPS, activa cookies seguras. En local déjalo en false o sin definir.
AUTH_COOKIE_SECURE=false
# Para generar una clave aleatoria en tu terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Luego pega el resultado como valor de NEXTAUTH_SECRET

# Push Notifications (VAPID keys)
# Generar claves: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=tu-clave-publica-vapid-aqui
VAPID_PRIVATE_KEY=tu-clave-privada-vapid-aqui
VAPID_SUBJECT=mailto:tu@email.com

# Server-side reminders
# Usalo para llamar /api/push/reminders desde cron sin una sesion web.
CRON_SECRET=pon-aqui-un-token-largo-aleatorio

# Aura / Ollama
AURA_API_KEY=pon-aqui-un-token-largo-para-aura
OLLAMA_URL=http://localhost:11434/api
AURA_MODEL=hermes3:8b
